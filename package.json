{
  "name": "codex-feishu-bridge",
  "version": "0.2.4",
  "description": "A focused Feishu/Lark bridge for local Codex.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jiao-Joe/codex-feishu-bridge.git"
  },
  "homepage": "https://github.com/Jiao-Joe/codex-feishu-bridge#readme",
  "bugs": {
    "url": "https://github.com/Jiao-Joe/codex-feishu-bridge/issues"
  },
  "type": "commonjs",
  "main": "src/index.js",
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "bot",
    "cli",
    "remote",
    "gateway"
  ],
  "files": [
    "bin",
    "docs",
    "src",
    "CHANGELOG.md",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "codex-im": "./bin/codex-im.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "feishu-bot": "node ./bin/codex-im.js",
    "check": "find src bin scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test:markdown": "node ./scripts/test-assistant-markdown.js",
    "test:card-content": "node ./scripts/test-card-reply-content.js",
    "test:media": "node ./scripts/test-media-fixtures.js",
    "test:directives": "node ./scripts/test-outbound-directives.js",
    "privacy:scan": "node ./scripts/privacy-scan.js",
    "pack:dry-run": "npm pack --dry-run",
    "check:release": "npm run check && npm run test:markdown && npm run test:card-content && npm run test:media && npm run test:directives && npm run privacy:scan && npm audit --omit=dev && npm run pack:dry-run"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.62.0",
    "axios": "^1.15.2",
    "dotenv": "^16.4.7",
    "ws": "^8.19.0"
  },
  "overrides": {
    "axios": "^1.15.2"
  }
}
