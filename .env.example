# Feishu app credentials (use separate apps for local and cloud instances)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Codex defaults for newly bound workspaces
CODEX_IM_DEFAULT_CODEX_MODEL=gpt-5.3-codex
CODEX_IM_DEFAULT_CODEX_EFFORT=medium
CODEX_IM_DEFAULT_CODEX_ACCESS_MODE=default

# Bot behavior
CODEX_IM_BRIDGE_MODE=thin
CODEX_IM_BRIDGE_PASSTHROUGH_TO_CODEX=true
CODEX_IM_DEFAULT_WORKSPACE_ID=default
CODEX_IM_INSTANCE_LABEL=local
CODEX_IM_FEISHU_STREAMING_OUTPUT=true
CODEX_IM_FEISHU_CARDKIT_STREAMING=true
CODEX_IM_FEISHU_PLAIN_TEXT_FALLBACK=false

# Capability flags shown by `/codex doctor`
# Set these only after the corresponding cloud/local runtime has been verified.
CODEX_IM_GITHUB_ENABLED=false
CODEX_IM_CANVA_ENABLED=false
CODEX_IM_CLOUDFLARE_ENABLED=false
CODEX_IM_CHROME_ENABLED=false

# Feishu outbound transient retry controls
CODEX_IM_FEISHU_RETRY_MAX_ATTEMPTS=3
CODEX_IM_FEISHU_RETRY_BASE_DELAY_MS=300

# Restrict bindable workspace roots (comma-separated absolute paths)
CODEX_IM_WORKSPACE_ALLOWLIST=

# Optional explicit Codex endpoint. Leave empty to spawn `codex app-server`.
CODEX_IM_CODEX_ENDPOINT=

# Optional extension file (private hooks outside this repo)
CODEX_IM_EXTENSIONS_FILE=

# Legacy standard-mode scheduled morning briefing.
# In the default thin mode this is ignored; prefer Codex scheduled tasks.
CODEX_IM_MORNING_BRIEFING_ENABLED=false
CODEX_IM_MORNING_BRIEFING_CRON=0 8 * * *
CODEX_IM_MORNING_BRIEFING_TIMEZONE=Asia/Shanghai
CODEX_IM_MORNING_BRIEFING_CHAT_ID=
CODEX_IM_MORNING_BRIEFING_WORKSPACE_ROOT=
CODEX_IM_MORNING_BRIEFING_MODEL=
CODEX_IM_MORNING_BRIEFING_EFFORT=
CODEX_IM_MORNING_BRIEFING_ACCESS_MODE=default
CODEX_IM_MORNING_BRIEFING_PROMPT_FILE=
CODEX_IM_MORNING_BRIEFING_TITLE=飞书晨报

# Legacy standard-mode appointment reminder subsystem.
# In the default thin mode appointment-like messages go to Codex.
CODEX_IM_APPOINTMENT_REMINDER_ENABLED=false
CODEX_IM_APPOINTMENT_NL_INTERCEPT_ENABLED=false
CODEX_IM_APPOINTMENT_TIMEZONE=Asia/Shanghai
CODEX_IM_APPOINTMENT_SCAN_INTERVAL_SEC=60

# Legacy standard-mode local suggestion intercepts.
# Keep false when every normal Feishu message should enter Codex.
CODEX_IM_PLUGIN_ROUTE_INTERCEPT_ENABLED=false

# Optional Mem0 memory extension
# Example:
# CODEX_IM_EXTENSIONS_FILE=./extensions/mem0-extension.js
# MEM0_ENABLED=true
# MEM0_BASE_URL=https://api.mem0.ai
# MEM0_API_KEY=m0_xxx
# MEM0_USER_ID_PREFIX=feishu
# MEM0_SEARCH_LIMIT=5
# MEM0_TIMEOUT_MS=15000

# Session persistence (keep isolated per instance)
# local example: /Users/you/.codex-im/sessions-local.json
# cloud example: /srv/codex-feishu-bridge/state/sessions-cloud.json
CODEX_IM_SESSIONS_FILE=/Users/your-name/.codex-im/sessions.json

# Private attachment cache (keep isolated per instance)
# For snap-based Codex on Linux, prefer a path under ~/snap/codex/common so localImage files are visible to Codex.
CODEX_IM_ATTACHMENTS_DIR=/Users/your-name/.codex-feishu-bridge/attachments
CODEX_IM_MAX_IMAGE_BYTES=10485760
CODEX_IM_MAX_ATTACHMENT_BYTES=104857600
