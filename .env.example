# Feishu app credentials (use separate apps for local and cloud instances)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Codex defaults for newly bound workspaces
CODEX_IM_DEFAULT_CODEX_MODEL=gpt-5.3-codex
CODEX_IM_DEFAULT_CODEX_EFFORT=medium
CODEX_IM_DEFAULT_CODEX_ACCESS_MODE=default

# Bot behavior
CODEX_IM_DEFAULT_WORKSPACE_ID=default
CODEX_IM_FEISHU_STREAMING_OUTPUT=true
CODEX_IM_FEISHU_CARDKIT_STREAMING=true

# Feishu outbound transient retry controls
CODEX_IM_FEISHU_RETRY_MAX_ATTEMPTS=3
CODEX_IM_FEISHU_RETRY_BASE_DELAY_MS=300

# Restrict bindable workspace roots (comma-separated absolute paths)
CODEX_IM_WORKSPACE_ALLOWLIST=

# Optional explicit Codex endpoint. Leave empty to spawn `codex app-server`.
CODEX_IM_CODEX_ENDPOINT=

# Optional extension file (private hooks outside this repo)
CODEX_IM_EXTENSIONS_FILE=

# Optional Mem0 memory extension
# Example:
# CODEX_IM_EXTENSIONS_FILE=./extensions/mem0-extension.js
# MEM0_ENABLED=true
# MEM0_BASE_URL=https://api.mem0.ai
# MEM0_API_KEY=m0_xxx
# MEM0_USER_ID_PREFIX=feishu
# MEM0_SEARCH_LIMIT=5
# MEM0_TIMEOUT_MS=15000

# Session persistence (keep isolated per instance)
# local example: /Users/you/.codex-im/sessions-local.json
# cloud example: /srv/codex-feishu-bridge/state/sessions-cloud.json
CODEX_IM_SESSIONS_FILE=/Users/your-name/.codex-im/sessions.json

# Private attachment cache (keep isolated per instance)
CODEX_IM_ATTACHMENTS_DIR=/Users/your-name/.codex-feishu-bridge/attachments
CODEX_IM_MAX_IMAGE_BYTES=10485760
CODEX_IM_MAX_ATTACHMENT_BYTES=104857600
